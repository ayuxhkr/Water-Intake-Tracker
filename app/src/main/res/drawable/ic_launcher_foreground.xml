<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Water drop main shape with gradient -->
    <path android:pathData="M54,18 C54,18 24,52 24,70 C24,86.5 37.5,100 54,100 C70.5,100 84,86.5 84,70 C84,52 54,18 54,18 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="18"
                android:endX="54"
                android:endY="100"
                android:type="linear">
                <item android:offset="0.0" android:color="#4FC3F7" /> <!-- Light cyan-blue -->
                <item android:offset="0.6" android:color="#2196F3" /> <!-- Material blue -->
                <item android:offset="1.0" android:color="#0D47A1" /> <!-- Deep blue -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Glowing reflection curve on the left side of the droplet -->
    <path
        android:pathData="M34,70 C34,57 44,40 51,30 C50,34 38,54 38,70 C38,78 41,83 41,83 C41,83 34,77 34,70 Z"
        android:fillColor="#80FFFFFF" />

    <!-- Soft highlight spot at the top-right -->
    <path
        android:pathData="M60,34 C64,38 66,44 65,46 C64,48 60,46 56,42 C52,38 52,34 54,32 C56,30 56,30 60,34 Z"
        android:fillColor="#40FFFFFF" />
        
    <!-- Bottom gloss reflection -->
    <path
        android:pathData="M40,84 C45,90 53,92 57,92 C65,92 72,87 72,87 C72,87 65,88 57,88 C49,88 43,84 40,84 Z"
        android:fillColor="#50FFFFFF" />
</vector>
